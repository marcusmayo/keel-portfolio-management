# Copy is NOT needed: infra/scripts/bootstrap.sh creates keel.env for you.
# This file documents every variable.

# --- required ---
# bootstrap.sh generates + enrolls this
TOTP_SECRET=
# Anthropic key... OR, in gateway mode, the
ANTHROPIC_API_KEY=
                             # LITELLM_MASTER_KEY value below (claude -p
                             # authenticates to the GATEWAY, not to Anthropic)

# --- optional: model selection ---
# e.g. claude-sonnet-4-5
ANTHROPIC_MODEL=

# --- optional: gateway mode (non-Anthropic model via LiteLLM) ---
# Point claude -p at the gateway; it routes to another provider. Full procedure:
# see the "Model selection" section in the top-level README.
#
# LITELLM_CONFIG selects the gateway config -- it is a COMPOSE-TIME shell var,
# NOT a keel.env var. Pass it on the `up` line (like KEEL_PUBLISH_ADDR):
#   sudo env KEEL_PUBLISH_ADDR=<addr> LITELLM_CONFIG=openrouter.yaml \
#     docker compose --profile gateway up -d
#
# Then set in keel.env (OpenRouter -- the keyless cross-provider path):
# ANTHROPIC_BASE_URL=http://gateway:4000
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_SMALL_FAST_MODEL=claude-3-5-haiku-20241022
# OPENROUTER_API_KEY=sk-or-v1-...     # keep ANTHROPIC_API_KEY as your real key
#
# gemini.yaml / ollama.yaml instead use a self-invented LITELLM_MASTER_KEY in
# ANTHROPIC_API_KEY + a provider key (GEMINI_API_KEY=AIza..., none for ollama).
# Why >=1.92 configs are keyless: infra/docs/gateway-findings.md
