# Copy is NOT needed: infra/scripts/bootstrap.sh creates keel.env for you.
# This file documents every variable.

# --- required ---
TOTP_SECRET=                 # bootstrap.sh generates + enrolls this
ANTHROPIC_API_KEY=           # Anthropic key... OR, in gateway mode, the
                             # LITELLM_MASTER_KEY value below (claude -p
                             # authenticates to the GATEWAY, not to Anthropic)

# --- optional: model selection ---
ANTHROPIC_MODEL=             # e.g. claude-sonnet-4-5

# --- optional: gateway mode (use a non-Anthropic model) ---
# 1. docker compose --profile gateway up -d
# 2. set ANTHROPIC_BASE_URL below + put LITELLM_MASTER_KEY in ANTHROPIC_API_KEY
# ANTHROPIC_BASE_URL=http://gateway:4000
# LITELLM_CONFIG=gemini.yaml     # or ollama.yaml (see infra/docker/litellm/)
# LITELLM_MASTER_KEY=sk-...      # you INVENT this; it is not issued by anyone
# GEMINI_API_KEY=AIza...         # real key: https://aistudio.google.com  (free tier)
# Ollama needs no key, but the host must run: OLLAMA_HOST=0.0.0.0 ollama serve
